######## 基本环境 ########
# 运行环境：dev=开发，prod=生产
APP_ENV=dev

# 后端 API 监听端口
API_PORT=8787


######## 数据库相关 ########
# MySQL 连接串：mysql+pymysql://用户名:密码@主机:端口/数据库名
# 开发环境可留空，将使用 SQLite
MYSQL_DSN=

# SQLite 路径（仅当 MYSQL_DSN 为空时使用）
SQLITE_DSN=sqlite:///./data/app.db

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30


######## Redis / Celery ########
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 开发环境建议 true，任务同步执行，无需单独起 worker
CELERY_TASK_ALWAYS_EAGER=true

SUBMIT_LOCK_TTL_SEC=30


######## 业务规则 ########
FREE_SUBMIT_LIMIT=2
FREE_DAILY_LIMIT=5
RETEST_PRICE_STARS=25
COMPAT_PRICE_STARS=50
GPT_DAILY_CAP=5000
COMPAT_RETRY_LIMIT=3
COMPAT_TIMEOUT_SEC=90


######## Telegram 相关 ########
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_PROVIDER_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=your_webhook_secret
TELEGRAM_BOT_USERNAME=@your_bot_username
TELEGRAM_API_BASE_URL=https://api.telegram.org

# 开发环境可设为 false 便于本地调试
TELEGRAM_INIT_DATA_REQUIRED=false
TELEGRAM_WEBHOOK_SECRET_REQUIRED=false
TELEGRAM_INIT_DATA_MAX_AGE_SEC=3600

LOCAL_DEV_USER_ID=100001


######## OpenAI 相关 ########
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_PROFILE=gpt-4o-mini
OPENAI_MODEL_COMPAT=gpt-4o-mini
OPENAI_TIMEOUT_SEC=30
# 使用代理或自建网关时填写
OPENAI_BASE_URL=
